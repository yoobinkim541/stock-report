# ─────────────────────────────────────────────────────────────────────────
# Stock Report — 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 이름 변경 후 실제 값을 입력하세요.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────

# ── 텔레그램 봇 설정 (필수) ────────────────────────────────────────────
# @BotFather 에서 발급한 봇 토큰
STOCK_BOT_TOKEN=your_telegram_bot_token_here

# 수신할 텔레그램 chat_id (선택, 기본값: 5771238245)
# https://api.telegram.org/bot{TOKEN}/getUpdates 에서 확인
# STOCK_BOT_CHAT_ID=5771238245

# ── 외부 API (선택) ────────────────────────────────────────────────────
# SaveTicker API 베이스 URL (기본: https://saveticker.com/api)
# SAVE_TICKER_API_BASE=https://saveticker.com/api

# ── 리포트 스캔 범위 (선택) ────────────────────────────────────────────
# NASDAQ 100 스캔 종목 수 (기본: 100, 줄이면 실행 속도 향상)
# INVESTMENT_REPORT_MAX_NASDAQ_SCAN=100

# KOSPI 스캔 종목 수 (기본: 30)
# INVESTMENT_REPORT_MAX_KOSPI_SCAN=30

# 리포트용 Arca Live 수집 페이지 수 (기본: 1)
# INVESTMENT_REPORT_ARCA_PAGES=1

# AI 콘솔/수집기 Arca 프록시 (선택) — 경매 에이전트 SOCKS 터널 재사용
# STOCK_COLLECTOR_ARCA_PROXY=socks5://127.0.0.1:1080

# ── LLM 리포트 설명/판단근거 (선택) ─────────────────────────────────
# 일일 투자 리포트 LLM 보조 설명 (deliver 스크립트 기본: 1)
# INVESTMENT_REPORT_LLM_ENABLED=1

# 일일 투자 리포트 보유종목 컨텍스트 판단근거 (기본: 1, shadow=설명만)
# INVESTMENT_REPORT_LLM_DECISION_ENABLED=1
# INVESTMENT_REPORT_LLM_DECISION_MODE=shadow
# INVESTMENT_REPORT_LLM_MODEL=gpt-5-mini
# INVESTMENT_REPORT_LLM_PROVIDER=openai-codex

# 국내/해외 모의투자 현황 리포트 LLM 판단근거 (기본: 1, 주문 영향 없음)
# MOCK_REPORT_LLM_ENABLED=1
# MOCK_REPORT_LLM_MODEL=gpt-5-mini
# MOCK_REPORT_LLM_PROVIDER=openai-codex
# MOCK_REPORT_LLM_TIMEOUT=75
# 국내 모의 주문 즉시 알림에도 LLM 판단근거 몇 줄 추가 (기본: MOCK_REPORT_LLM_ENABLED와 동일)
# KR_MOCK_NOTIFY_LLM_ENABLED=1

# 국내/해외 모의 리밸런싱 주문 LLM shadow 리뷰 (기본: 1)
# shadow=주문 변경 없음, guarded_apply=매수 block/reduce_half만 제한 적용
# MOCK_ORDER_LLM_ENABLED=1
# MOCK_ORDER_LLM_MODE=shadow
# MOCK_ORDER_LLM_MODEL=gpt-5-mini
# MOCK_ORDER_LLM_PROVIDER=openai-codex
# MOCK_ORDER_LLM_TIMEOUT=75
# MOCK_ORDER_LLM_HORIZONS=5,20,60
# MOCK_ORDER_LLM_REPORT_HORIZON=20

# ── 실행 환경 (선택) ─────────────────────────────────────────────────
# 프로젝트 경로 (기본: /home/ubuntu/projects/stock-report)
# STOCK_REPORT_PROJECT_DIR=/home/ubuntu/projects/stock-report

# Python 바이너리 경로 (기본: python3)
# PYTHON_BIN=python3

# ── 키움 REST API (국내주식 잔고 동기화) ─────────────────────────────
# openapi.kiwoom.com → 앱 등록 → API Key / Secret 발급
KIWOOM_API_KEY=your_api_key_here
KIWOOM_API_SECRET=your_api_secret_here

# ── 키움 잔고 동기화 서버 (portfolio_sync_server.py) ──────────────────
# Windows 노트북 → Ubuntu 서버 잔고 수신용
# python3 -c "import secrets; print(secrets.token_hex(32))" 로 생성
SYNC_TOKEN=여기에_랜덤_토큰_생성해서_입력

# 동기화 서버 포트 (기본: 8765)
# Oracle Cloud Ingress rule에 이 포트 추가 필요
# SYNC_PORT=8765

# ── 단기(1m/5m) 모의 트레이딩 (docs/intraday-mock-trading-design.md) ──────────
# 전부 기본 off/shadow — 켜기 전엔 무해. 실계좌 주문 경로 0 불변.
# INTRADAY_BARS_ENABLED=false        # kis_stream 틱→1분봉 집계 sink (수집 먼저 켤 것)
# INTRADAY_MOCK_ENABLED=false        # 매 1분 단기 모의 엔진 (crons/intraday_mock_track)
# INTRADAY_SHADOW_ONLY=true          # 가상체결만 원장 기록 (게이트 통과 후에만 false)
# INTRADAY_MARKETS=kr,us
# INTRADAY_SCAN_ENABLED=true         # 동적 유니버스 스캐너 (거래대금·등락 상위)
# INTRADAY_SCAN_TOP_KR=5
# INTRADAY_SCAN_TOP_US=4
# INTRADAY_MIN_TURNOVER_KRW=30000000000   # KR 후보 거래대금 하한 (300억)
# INTRADAY_UNIVERSE_KR=005930,000660,373220,005380,035420   # 스캐너 실패 시 정적 폴백
# INTRADAY_UNIVERSE_US=QQQ
# INTRADAY_SLEEVE_FRAC=0.10          # 모의 NAV 중 단기 슬리브 비율
# INTRADAY_RISK_PER_TRADE=0.005      # 트레이드당 슬리브 리스크 (사이징)
# INTRADAY_MAX_TRADES_DAY=0          # 0=시장별 일일 거래횟수 제한 없음
# INTRADAY_MAX_CONCURRENT_POS=0      # 0=동시 포지션 제한 없음
# INTRADAY_COOLDOWN_MIN=0            # 0=같은 종목 즉시 재진입 허용
# INTRADAY_DAILY_LOSS_HALT=0.015     # 슬리브 일손실 -1.5% 도달 시 당일 정지
# INTRADAY_MAX_SPREAD_BPS_KR=25      # 진입 스프레드 상한 (KR 은 max(2틱, 상한) 적용)
# INTRADAY_MAX_SPREAD_BPS_US=5
# INTRADAY_FLAT_BUFFER_MIN=15        # 마감 N분 전 강제 청산
